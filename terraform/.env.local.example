# Copy to terraform/.env.local (gitignored) and fill in real values.
# Source before running terraform commands: `set -a; source .env.local; set +a`
# or run via the `./tf` wrapper script which does this automatically.

# Hetzner Cloud - Read & Write scope, used by hcloud provider
HCLOUD_TOKEN=

# Cloudflare - scoped to Zone:DNS:Edit for devonbooker.dev
CLOUDFLARE_API_TOKEN=
