{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Uptime and TLS posture for monitored URLs",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Uptime % (last 1h)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "sum by (url) (increase(uptime_pings_total{status=\"up\"}[1h])) / sum by (url) (increase(uptime_pings_total[1h])) * 100",
          "legendFormat": "{{url}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 2,
      "title": "Latest latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "uptime_latency_ms",
          "legendFormat": "{{url}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "Cert days until expiry",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "tls_cert_days_until_expiry",
          "legendFormat": "{{url}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "title": "Weak TLS protocol (< TLS 1.2)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "sum(tls_weak_protocol)",
          "legendFormat": "weak protocol count",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 5,
      "title": "Weak TLS cipher (stdlib InsecureCipherSuites)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "sum(tls_weak_cipher)",
          "legendFormat": "weak cipher count",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 6,
      "title": "Negotiated TLS protocol + cipher per URL",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 23 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "tls_info",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "url": "URL", "protocol": "Protocol", "cipher": "Cipher" },
            "indexByName": {}
          }
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm" }
    },
    {
      "id": 7,
      "title": "Security header matrix (1 = present, 0 = missing)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "posture-prom" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "posture-prom" },
          "expr": "security_header_present",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": {},
            "indexByName": {}
          }
        },
        {
          "id": "groupingToMatrix",
          "options": { "columnField": "header", "rowField": "url", "valueField": "Value" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "cellOptions": { "type": "color-background" }, "align": "center" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "showHeader": true, "cellHeight": "sm" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["posture", "uptime", "tls"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Uptime & TLS Posture",
  "uid": "posture",
  "version": 1,
  "weekStart": ""
}
